# LLM provider: "ollama" | "openai" | "anthropic"
LLM_PROVIDER=ollama

# Ollama (local PC via Tailscale)
OLLAMA_BASE_URL=http://your-pc.ts.net:8100
OLLAMA_MODEL=qwen3:8b
OLLAMA_EMBED_MODEL=mxbai-embed-large:latest

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-5.4

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-5

# Paths (inside container)
DB_PATH=/data/travel.db
CHROMA_PATH=/chroma

# Travel date filter — entries before this date are excluded from ingestion
TRAVEL_START_DATE=2026-06-11

# API security
TREVOR_API_KEY=change-me

# TravelNet service (same Docker network)
TRAVELNET_URL=http://ingest:8000
TRAVELNET_API_KEY=change-me

# Compute node SSH
COMPUTE_HOST=your-pc.ts.net
COMPUTE_PORT=2222
COMPUTE_USERNAME=compute
COMPUTE_PASSWORD=change-me
COMPUTE_INACTIVITY_TIMEOUT=900
